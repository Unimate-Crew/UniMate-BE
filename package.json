{
  "name": "meket-for-u-server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/meket-for-u-server/test/jest-e2e.json",
    "build:api-server:dev": "nest build api-server",
    "start:api-server:dev": "nest start api-server --watch",
    "start:api-server:debug": "nest start api-server --watch --debug --inspect",
    "build:chat-server:dev": "nest build chat-server",
    "start:chat-server:dev": "nest start chat-server --watch",
    "start:chat-server:debug": "nest start chat-server --watch --debug --inspect",
    "migration:create": "npx mikro-orm migration:create --config=./libs/database/mikro-orm.config.ts",
    "migration:up": "npx mikro-orm migration:up --config=./libs/database/mikro-orm.config.ts",
    "migration:down": "npx mikro-orm migration:down --config=./libs/database/mikro-orm.config.ts",
    "migration:pending": "npx mikro-orm migration:pending --config=./libs/database/mikro-orm.config.ts",
    "schema:update": "npx mikro-orm schema:update --config=./libs/database/mikro-orm.config.ts --dump",
    "schema:drop": "npx mikro-orm schema:drop --config=./libs/database/mikro-orm.config.ts --dump",
    "seeder:run": "npx mikro-orm seeder:run --config=./libs/database/mikro-orm.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.825.0",
    "@aws-sdk/client-sqs": "^3.825.0",
    "@aws-sdk/s3-request-presigner": "^3.825.0",
    "@mikro-orm/core": "^6.4.13",
    "@mikro-orm/migrations": "^6.4.13",
    "@mikro-orm/mysql": "^6.4.13",
    "@mikro-orm/nestjs": "^6.1.1",
    "@mikro-orm/reflection": "^6.4.13",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.4.20",
    "@nestjs/swagger": "^8.1.1",
    "@nestjs/websockets": "^10.4.20",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/express-session": "^1.18.1",
    "@types/passport-jwt": "^4.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^16.5.0",
    "express-basic-auth": "^1.2.1",
    "express-session": "^1.18.1",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.0",
    "nest-winston": "^1.10.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-kakao": "^1.0.1",
    "passport-naver": "^1.0.6",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@mikro-orm/cli": "^6.4.13",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@app/database(|/.*)$": "<rootDir>/libs/database/src/$1",
      "^@app/common(|/.*)$": "<rootDir>/libs/common/src/$1",
      "^@app/redis(|/.*)$": "<rootDir>/libs/redis/src/$1"
    }
  },
  "mikro-orm": {
    "useTsNode": true,
    "configPaths": [
      "./libs/database/mikro-orm.config.ts"
    ]
  }
}
